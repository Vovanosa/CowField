generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountRole {
  admin
  user
}

enum SessionRole {
  admin
  user
  guest
}

enum ActorType {
  user
  guest
}

enum Difficulty {
  light
  easy
  medium
  hard
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String?              @map("password_hash")
  googleId            String?              @unique @map("google_id")
  role                AccountRole
  displayName         String               @map("display_name")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  levelProgress       LevelProgress[]
  statisticsTotals    PlayerStatisticsTotal[]
  authoredLevels      Level[]

  @@map("users")
}

model Session {
  token       String     @id
  actorKey    String     @map("actor_key")
  actorType   ActorType  @map("actor_type")
  role        SessionRole
  userId      String?    @map("user_id")
  email       String?
  displayName String     @map("display_name")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([actorKey], map: "sessions_actor_key_idx")
  @@index([userId], map: "sessions_user_id_idx")
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  email     String
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@map("password_reset_tokens")
}

model LevelProgress {
  id              String     @id @default(uuid())
  actorType       ActorType  @map("actor_type")
  userId          String?    @map("user_id")
  difficulty      Difficulty
  levelNumber     Int        @map("level_number")
  bestTimeSeconds Int?       @map("best_time_seconds")
  completedAt     DateTime?  @map("completed_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  user            User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, difficulty, levelNumber], map: "level_progress_user_level_unique")
  @@index([actorType], map: "level_progress_actor_type_idx")
  @@index([difficulty, levelNumber], map: "level_progress_level_lookup_idx")
  @@map("level_progress")
}

model PlayerStatisticsTotal {
  id                         String     @id @default(uuid())
  actorType                  ActorType  @map("actor_type")
  userId                     String?    @map("user_id")
  totalCompletedLevels       Int        @default(0) @map("total_completed_levels")
  totalBullPlacements        Int        @default(0) @map("total_bull_placements")
  totalCompletionTimeSeconds Int        @default(0) @map("total_completion_time_seconds")
  updatedAt                  DateTime   @updatedAt @map("updated_at")
  user                       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId], map: "player_statistics_totals_user_id_unique")
  @@index([actorType], map: "player_statistics_totals_actor_type_idx")
  @@map("player_statistics_totals")
}

model Level {
  id              String     @id @default(uuid())
  difficulty      Difficulty
  levelNumber     Int        @map("level_number")
  title           String
  gridSize        Int        @map("grid_size")
  pensByCell      Json       @map("pens_by_cell")
  cowsByCell      Json       @map("cows_by_cell")
  createdByUserId String?    @map("created_by_user_id")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  createdByUser   User?      @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([difficulty, levelNumber], map: "levels_difficulty_level_number_unique")
  @@index([createdByUserId], map: "levels_created_by_user_id_idx")
  @@map("levels")
}
